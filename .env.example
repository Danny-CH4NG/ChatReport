# ── LLM ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── 資料庫類型切換 ───────────────────────────────────
# 可選值：postgres | vertica
DB_TYPE=vertica

# ── 通用連線參數（postgres / vertica 共用） ───────────
DB_HOST=vertica.example.com
DB_PORT=5433
DB_NAME=traffic_analytics
DB_USER=svc_traffic_user
DB_PASSWORD=your_password_here

# ── Vertica 專屬 ─────────────────────────────────────
# 查詢時所有資料表的 schema 前綴（等同 PostgreSQL search_path）
DB_SCHEMA=traffic_schema
# 連線逾時（秒），雲端連線建議 10-30
DB_CONNECTION_TIMEOUT=15
# SSL 連線模式：disable | require | verify-ca | verify-full
DB_SSL_MODE=disable

# ── PostgreSQL 模式（DB_TYPE=postgres）說明 ───────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=traffic_db
# DB_USER=traffic_user
# DB_SCHEMA=public
# 啟動方式：docker compose --profile postgres up -d

# ── Chainlit ─────────────────────────────────────────
CHAINLIT_AUTH_SECRET=random_secret_32chars_change_me
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000
